{
  "name": "godaddy-mcp",
  "version": "0.1.0",
  "description": "MCP server for GoDaddy API (Domains + DNS).",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/thiagoorodrigues/godaddy-mcp.git"
  },
